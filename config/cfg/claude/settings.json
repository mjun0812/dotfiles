{
    "permissions": {
        "allow": [
            "Bash(git status:*)",
            "Bash(git diff:*)",
            "Bash(git branch:*)",
            "Bash(git log:*)",
            "Bash(eza:*)",
            "Bash(rgrep:*)",
            "Bash(fd:*)"
        ],
        "deny": [
            "Read(.env)",
            "Read(~/.aws/**)"
        ],
        "ask": [
            "Bash(rm:*)",
            "Bash(git commit:*)",
            "Bash(git push:*)"
        ]
    },
    "includeCoAuthoredBy": false,
    "statusLine": {
        "type": "command",
        "command": "bun x ccusage statiusline",
        "padding": 0
    }
}
