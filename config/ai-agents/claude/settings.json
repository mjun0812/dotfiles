{
  "attribution": {
    "commit": "",
    "pr": "🤖 Generated with [Claude Code](https://claude.com/claude-code)"
  },
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git log:*)",
      "Bash(ls:*)",
      "Bash(eza:*)",
      "Bash(grep:*)",
      "Bash(rgrep:*)",
      "Bash(fd:*)",
      "Bash(cat:*)",
      "Bash(bat:*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(~/.aws/**)"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(gh pr create:*)"
    ],
    "defaultMode": "plan"
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.dotfiles/script/notify.sh 'Claude Code' 'タスクが完了しました ✅'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.dotfiles/script/notify.sh 'Claude Code' '入力を待っています 📝'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.dotfiles/config/ai-agents/claude/statusline.sh",
    "padding": 0
  },
  "language": "japanese",
  "plansDirectory": "./docs/plans",
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true
  }
}
