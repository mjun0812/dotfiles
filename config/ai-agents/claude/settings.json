{
  "attribution": {
    "commit": "",
    "pr": "🤖 Generated with [Claude Code](https://claude.com/claude-code)"
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "~/.dotfiles/script/notify.sh --osc 'Claude Code' '入力を待っています 📝'",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "~/.dotfiles/script/check_plan_rename.sh ./.claude/plans",
            "type": "command"
          }
        ],
        "matcher": "ExitPlanMode"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "~/.dotfiles/script/notify.sh --osc 'Claude Code' 'タスクが完了しました ✅'",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "language": "japanese",
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(ls:*)",
      "Bash(eza:*)",
      "Bash(grep:*)",
      "Bash(rgrep:*)",
      "Bash(fd:*)",
      "Bash(cat:*)",
      "Bash(bat:*)",
      "Skill",
      "WebFetch",
      "WebSearch",
      "Read(./claude/plans/**)",
      "Edit(./.claude/plans/**)",
      "Write(./.claude/plans/**)"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(git push:*)",
      "Bash(gh pr create:*)"
    ],
    "defaultMode": "plan",
    "deny": [
      "Read(.env)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)"
    ]
  },
  "plansDirectory": "./.claude/plans",
  "statusLine": {
    "command": "~/.dotfiles/config/ai-agents/claude/statusline.sh",
    "padding": 0,
    "type": "command"
  }
}