{
  "attribution": {
    "commit": "",
    "pr": "🤖 Generated with Claude Code"
  },
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(ls *)",
      "Bash(eza *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rgrep *)",
      "Bash(fd *)",
      "Bash(cat *)",
      "Bash(bat *)",
      "Bash(tree *)",
      "Bash(gh *)",
      "Bash(bunx *)",
      "Bash(bun *)",
      "Bash(uvx *)",
      "Bash(uv *)",
      "Bash(ruff *)",
      "Bash(ty *)",
      "Bash(mise *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pytest *)",
      "Bash(make *)",
      "Bash(docker *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(touch *)",
      "Bash(wc *)",
      "Bash(diff *)",
      "Bash(jq *)",
      "Bash(which *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(tee *)",
      "Bash(stat *)",
      "Bash(realpath *)",
      "Bash(dirname *)",
      "Bash(basename *)",
      "Bash(date *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(curl *)",
      "Bash(xargs *)",
      "Bash(bash *)",
      "Bash(test *)",
      "Bash(rm /tmp/**)",
      "Bash(rm -f /tmp/**)",
      "Bash(rm -rf /tmp/**)",
      "Skill",
      "WebFetch",
      "WebSearch",
      "Read",
      "Search",
      "Edit(./.claude/plans/**)",
      "Write(./.claude/plans/**)",
      "Read(/tmp/**)",
      "Edit(/tmp/**)",
      "Write(/tmp/**)"
    ],
    "deny": [
      "Read(.env)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME/**)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(gh pr create *)",
      "Bash(gh issue create *)",
      "Bash(gh issue close *)",
      "Bash(gh pr close *)",
      "Bash(gh pr merge *)"
    ],
    "defaultMode": "auto",
    "additionalDirectories": [
      "/tmp"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "~/.dotfiles/script/rename-plan.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.dotfiles/script/notify.sh --osc 'Claude Code' '入力を待っています 📝'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.dotfiles/script/notify.sh --osc 'Claude Code' 'タスクが完了しました ✅'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.py",
    "padding": 0
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true,
    "codex@openai-codex": true,
    "skill-creator@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "language": "japanese",
  "effortLevel": "xhigh",
  "plansDirectory": "./.claude/plans",
  "skipDangerousModePermissionPrompt": true,
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
