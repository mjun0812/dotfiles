{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(ls *)",
      "Bash(eza *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rgrep *)",
      "Bash(fd *)",
      "Bash(cat *)",
      "Bash(bat *)",
      "Bash(tree *)",
      "Bash(gh *)",
      "Bash(bunx *)",
      "Bash(bun *)",
      "Bash(uvx *)",
      "Bash(uv *)",
      "Bash(ruff *)",
      "Bash(ty *)",
      "Bash(mise *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pytest *)",
      "Bash(make *)",
      "Bash(docker *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(touch *)",
      "Bash(wc *)",
      "Bash(diff *)",
      "Bash(jq *)",
      "Bash(which *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(tee *)",
      "Bash(stat *)",
      "Bash(realpath *)",
      "Bash(dirname *)",
      "Bash(basename *)",
      "Bash(date *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(curl *)",
      "Bash(xargs *)",
      "Bash(bash *)",
      "Bash(test *)",
      "Bash(rm /tmp/**)",
      "Bash(rm -f /tmp/**)",
      "Bash(rm -rf /tmp/**)",
      "Bash(rm /private/tmp/**)",
      "Bash(rm -f /private/tmp/**)",
      "Bash(rm -rf /private/tmp/**)",
      "Skill",
      "WebFetch",
      "WebSearch",
      "Read",
      "Search",
      "Edit(./.claude/plans/**)",
      "Write(./.claude/plans/**)",
      "Read(/tmp/**)",
      "Edit(/tmp/**)",
      "Write(/tmp/**)",
      "Read(/private/tmp/**)",
      "Edit(/private/tmp/**)",
      "Write(/private/tmp/**)"
    ],
    "deny": [
      "Read(.env)",
      "Read(./.env)",
      "Bash(sudo *)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME/**)",
      "Bash(curl * | sh *)",
      "Bash(wget * | sh *)",
      "Read(./secrets/**)"
    ],
    "ask": [],
    "defaultMode": "auto",
    "additionalDirectories": [
      "/tmp",
      "/private/tmp"
    ]
  },
  "model": "claude-fable-5[1m]",
  "hooks": {
    "PostToolUse": [],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.dotfiles/script/notify-claude-hook.sh notification"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.dotfiles/script/notify-claude-hook.sh stop"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.dotfiles/script/notify-claude-hook.sh stop_failure"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "bypass_permissions_disabled",
        "hooks": [
          {
            "type": "command",
            "command": "~/.dotfiles/script/notify-claude-hook.sh session_end"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.py",
    "padding": 0
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true,
    "codex@openai-codex": true,
    "skill-creator@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "language": "japanese",
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "plansDirectory": "./.claude/plans",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "remoteControlAtStartup": true,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}