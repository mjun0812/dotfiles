[user]
  name="Junya Morioka"
  email=mjun@mjunya.com
  signingkey = ~/.ssh/id_rsa.pub

[core]
  pager = delta
  editor=vim
  ignorecase=false
  excludesfile = ~/.gitignore
  quotepath = false

[branch]
  sort = -committerdate

[color]
  ui = true

[column]
  ui = auto

[commit]
  gpgsign = false
  verbose = true

[fetch]
  all = true
  prune = true
  pruneTags = true

[gpg]
  format = ssh

[help]
  autocorrect = prompt

[init]
  defaultBranch=main

[interactive]
  diffFilter = delta --color-only

[merge]
  conflictStyle = zdiff3

[pull]
  rebase=false

[push]
  default = simple
  autoSetupRemote = true
  followTags = true

[rebase]
  autoSquash = true
  autoStash = true
  updateRefs = true

[rerere]
  enabled = true
  autoupdate = true

[tag]
  sort = version:refname
  gpgsign = false

[alias]
  aicommit = !claude --model=haiku '/git:commit'
  aicommit-ja = !claude --model=haiku '/git:commit ja'
  prune-branch = "!f() { git fetch -p && git branch -vv | awk '/: gone]/{ if ($1 != \"*\" && $1 != \"+\") print $1 }' | while read -r branch; do git branch -D \"$branch\"; done; }; f"

[filter "lfs"]
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true
  clean = git-lfs clean -- %f

[ghq]
  root = ~/workspace

[ghq "https://github.com/mjun0812/"]
  root = ~/workspace

[delta]
  navigate = true
  dark = true
  side-by-side = true
  line-numbers = true

[include]
  path = ~/.gitconfig.local

