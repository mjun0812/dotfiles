[user]
  name="Junya Morioka"
  email=mjun@mjunya.com

[pull]
  rebase=false

[core]
  pager = delta
  editor=vim
  ignorecase=false

[init]
   defaultBranch=main

[color]
  ui = true

[fetch]
  prune = true

[push]
  autoSetupRemote = true

[merge]
  conflictStyle = zdiff3

[interactive]
  diffFilter = delta --color-only

[tag]
  sort = -v:refname

[alias]
  aicommit = !claude --model=haiku '/git:commit'
  aicommit-ja = !claude --model=haiku '/git:commit ja'
  prune-branch = "!f() { git fetch -p && git branch -vv | awk '/: gone]/{ if ($1 != \"*\" && $1 != \"+\") print $1 }' | while read -r branch; do git branch -D \"$branch\"; done; }; f"

[filter "lfs"]
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true
  clean = git-lfs clean -- %f

[ghq]
  root = ~/workspace

[ghq "https://github.com/mjun0812/"]
  root = ~/workspace

[delta]
  navigate = true
  dark = true
  side-by-side = true
  line-numbers = true

[include]
  path = ~/.gitconfig.local

