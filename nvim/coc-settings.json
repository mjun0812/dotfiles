{
  "coc.preferences.extensionUpdateCheck": "daily",
  "coc.preferences.formatOnSave": true,
  "coc.preferences.formatOnType": true,
  "coc.preferences.formatOnSaveTimeout": 500,
  "coc.preferences.willSaveHandlerTimeout": 500,
  "clangd.fallbackFlags": ["-std=c++11"],
  "pyright.enable": true,
  "python.formatting.blackArgs": ["--line-length", "99"],
  "python.formatting.provider": "black",
  "python.analysis.autoImportCompletions": false,
  "pyright.organizeimports.provider": "isort",
  "pyright.disableProgressNotifications": true,
  "pyright.inlayHints.functionReturnTypes": false,
  "pyright.inlayHints.variableTypes": false,
  "pylsp.enable": false,
  // "pylsp.builtin.enableInstallPylsIsort": false,
  // "pylsp.builtin.enableInstallPythonLspBlack": true,
  // "pylsp.plugins.black.line_length": 99,
  // "pylsp.configurationSources": ["flake8"],
  // "pylsp.plugins.flake8.enabled": true,
  // "pylsp.plugins.flake8.extendIgnore": ["E203", "E501"],
  // "pylsp.plugins.flake8.maxLineLength": 99,
  "pydocstring.formatter": "google",
  "markdownlint.config": {
    "line-length": false
  },
  "svelte.enable-ts-plugin": true
}
